# Environment
NODE_ENV=development
PORT=3001

# Database
MONGODB_URI=mongodb://localhost:27017/nirex

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secrets (min 32 characters)
JWT_ACCESS_SECRET=replace-with-32-plus-char-secret
JWT_REFRESH_SECRET=replace-with-32-plus-char-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30

# Cookie
COOKIE_DOMAIN=

# OAuth - Google (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/oauth/google/callback

# OAuth - GitHub (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/auth/oauth/github/callback

# Email (SMTP)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@localhost

# App URL
APP_URL=http://localhost:5173

# CORS
CORS_ORIGINS=http://localhost:5173

# Billing / Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=2025-04-30.basil
STRIPE_BILLING_PORTAL_CONFIGURATION_ID=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_AUTOMATIC_TAX_ENABLED=false
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
BILLING_WEBHOOK_STALE_RETRY_SECONDS=900
BILLING_SYNC_MIN_INTERVAL_SECONDS=120
BILLING_WEBHOOK_RATE_LIMIT_PER_MINUTE=600
BILLING_EMAIL_NOTIFICATIONS_ENABLED=true
BILLING_DEFAULT_SUCCESS_URL=http://localhost:5173/main/billing?checkout=success
BILLING_DEFAULT_CANCEL_URL=http://localhost:5173/main/billing?checkout=cancelled

# API Keys
API_KEY_SECRET_PEPPER=replace-with-a-random-32-plus-char-pepper-secret
API_KEY_PREFIX=nrx
API_KEY_DEFAULT_TTL_DAYS=365

# Two-Factor Authentication (TOTP)
TWO_FACTOR_ENCRYPTION_KEY=replace-with-a-random-32-plus-char-encryption-key
TWO_FACTOR_ISSUER=Nirex
TWO_FACTOR_SETUP_TTL_MINUTES=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_API_MAX=100
