{
  "name": "@nirex/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.tsx",
      "import": "./src/*.tsx",
      "default": "./src/*.tsx"
    },
    "./**/*": {
      "types": "./src/**/*.tsx",
      "import": "./src/**/*.tsx",
      "default": "./src/**/*.tsx"
    }
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.0.0"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "generate:component": "turbo gen react-component",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@nirex/eslint-config": "workspace:*",
    "@nirex/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "eslint": "^9.39.1",
    "react-router-dom": "^7.14.0",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@nirex/shared": "workspace:^",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "framer-motion": "^12.38.0",
    "react-icons": "^5.6.0",
    "sonner": "^1.7.0"
  }
}