{
  "name": "@nirex/shared",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts",
      "default": "./src/*.ts"
    },
    "./**/*": {
      "types": "./src/**/*.ts",
      "import": "./src/**/*.ts",
      "default": "./src/**/*.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@nirex/typescript-config": "workspace:*",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@radix-ui/react-tooltip": "^1.2.8",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.24.1"
  }
}